rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Hilfsfunktionen ─────────────────────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ── Spieler-Profile ─────────────────────────────────────
    // Beide Spieler dürfen alle Profile LESEN (für das Dashboard)
    // Jeder darf nur sein EIGENES Profil schreiben
    match /players/{userId} {
      allow read:  if isLoggedIn();
      allow write: if isLoggedIn() && isOwner(userId);
    }

    // ── Private Notizen ─────────────────────────────────────
    // Nur der Besitzer darf lesen und schreiben
    match /player_notes/{userId} {
      allow read, write: if isLoggedIn() && isOwner(userId);
    }

    // ── Duelle ──────────────────────────────────────────────
    // Beide Spieler dürfen alle Duelle lesen
    // Eingeloggte Spieler dürfen Duelle erstellen
    // Löschen: nur der Ersteller (gespeichert in createdBy – optional)
    match /duels/{duelId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow delete: if isLoggedIn(); // Beide können löschen (Bruder-Vertrauen)
      allow update: if isLoggedIn();
    }

    // ── Tauschbörse ─────────────────────────────────────────
    // Beide Spieler dürfen alles lesen
    // Jeder darf nur seine eigenen Einträge schreiben/löschen
    match /trades/{tradeId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isLoggedIn() && resource.data.uid == request.auth.uid;
      allow update: if isLoggedIn() && resource.data.uid == request.auth.uid;
    }

    // ── Ziele ────────────────────────────────────────────────
    // Jeder sieht nur seine eigenen Ziele!
    match /goals/{goalId} {
      allow read:   if isLoggedIn() && resource.data.uid == request.auth.uid;
      allow create: if isLoggedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isLoggedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isLoggedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
