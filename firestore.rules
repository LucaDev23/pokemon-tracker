rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }

    // Spieler-Profile: beide lesen, jeder nur eigenes schreiben
    match /players/{userId} {
      allow read:  if isLoggedIn();
      allow write: if isLoggedIn() && isOwner(userId);
    }

    // Private Notizen: nur Besitzer
    match /player_notes/{userId} {
      allow read, write: if isLoggedIn() && isOwner(userId);
    }

    // Spielzeit-Log: beide lesen (für Diagramm), jeder nur eigene schreiben
    match /playtime_log/{entryId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isLoggedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isLoggedIn() && resource.data.uid == request.auth.uid;
    }

    // Duelle: beide lesen und schreiben
    match /duels/{duelId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow delete: if isLoggedIn();
      allow update: if isLoggedIn();
    }

    // Tauschbörse: beide lesen, jeder nur eigene schreiben
    match /trades/{tradeId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isLoggedIn() && resource.data.uid == request.auth.uid;
      allow update: if isLoggedIn() && resource.data.uid == request.auth.uid;
    }

    // Ziele: nur Besitzer sieht eigene
    match /goals/{goalId} {
      allow read:   if isLoggedIn() && resource.data.uid == request.auth.uid;
      allow create: if isLoggedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isLoggedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isLoggedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
